ANDB_HTTP_ADDR=127.0.0.1:8080
ANDB_ENV=dev
# Runtime visibility profile: test|prod
# - test: transparent debug payload/log visibility
# - prod: debug fields stripped from JSON responses
APP_MODE=prod
ANDB_STORAGE_DSN=file:andb.db?cache=shared&mode=rwc
ANDB_CPP_LIB_PATH=./build/libandb_retrieval.dylib

# ─── Embedding Provider Selection ─────────────────────────────────────────────
# Options: tfidf|openai|zhipuai|cohere|vertexai|huggingface|onnx|gguf|tensorrt
ANDB_EMBEDDER=tfidf

# ─── Unified embedding env vars (used by all online providers) ────────────────
# Set ANDB_EMBEDDER to the desired provider, then fill the vars for that block.
# NOTE: bootstrap.go reads ANDB_EMBEDDER_* for ALL online providers.
# The old per-provider names (ANDB_OPENAI_API_KEY etc.) are NOT read by bootstrap.
ANDB_EMBEDDER_API_KEY=
ANDB_EMBEDDER_MODEL=
ANDB_EMBEDDER_BASE_URL=
ANDB_EMBEDDER_DIM=0
# 0 = auto-detect via probe request (not supported by all providers)
ANDB_EMBEDDER_TIMEOUT=30
# per-request timeout in seconds
ANDB_EMBEDDER_BATCH_SIZE=100
# inputs per HTTP request (online providers)

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# ANDB_EMBEDDER=openai
# ANDB_EMBEDDER_API_KEY=sk-xxx
# ANDB_EMBEDDER_BASE_URL=https://api.openai.com/v1
# ANDB_EMBEDDER_MODEL=text-embedding-3-small   # dim=1536
# ANDB_EMBEDDER_MODEL=text-embedding-3-large   # dim=3072
# ANDB_EMBEDDER_MODEL=text-embedding-ada-002   # dim=1536 (legacy)
# ANDB_EMBEDDER_DIM=1536

# ─── Azure OpenAI ─────────────────────────────────────────────────────────────
# ANDB_EMBEDDER=openai
# ANDB_EMBEDDER_API_KEY=<azure-key>
# ANDB_EMBEDDER_BASE_URL=https://<resource>.openai.azure.com/openai/deployments/<deploy-name>
# ANDB_EMBEDDER_MODEL=text-embedding-3-small
# ANDB_EMBEDDER_DIM=1536

# ─── Ollama (local OpenAI-compatible) ─────────────────────────────────────────
# ANDB_EMBEDDER=openai
# ANDB_EMBEDDER_API_KEY=ollama
# ANDB_EMBEDDER_BASE_URL=http://localhost:11434/v1
# ANDB_EMBEDDER_MODEL=nomic-embed-text          # dim=768
# ANDB_EMBEDDER_MODEL=mxbai-embed-large         # dim=1024
# ANDB_EMBEDDER_MODEL=all-minilm                # dim=384
# ANDB_EMBEDDER_DIM=768

# ─── ZhipuAI / GLM ────────────────────────────────────────────────────────────
# ANDB_EMBEDDER=zhipuai
# ANDB_EMBEDDER_API_KEY=xxx
# ANDB_EMBEDDER_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# ANDB_EMBEDDER_MODEL=embedding-3              # dim=2048
# ANDB_EMBEDDER_MODEL=embedding-2              # dim=1024 (legacy)
# ANDB_EMBEDDER_DIM=2048

# ─── Cohere ───────────────────────────────────────────────────────────────────
# ANDB_EMBEDDER=cohere
# ANDB_EMBEDDER_API_KEY=xxx
# ANDB_EMBEDDER_MODEL=embed-english-v3.0        # dim=1024
# ANDB_EMBEDDER_MODEL=embed-multilingual-v3.0   # dim=1024
# ANDB_EMBEDDER_MODEL=embed-english-light-v3.0  # dim=384
# ANDB_EMBEDDER_DIM=1024   # required for Cohere

# ─── Google Vertex AI ─────────────────────────────────────────────────────────
# ANDB_EMBEDDER=vertexai
ANDB_VERTEXAI_PROJECT=my-project
ANDB_VERTEXAI_LOCATION=us-central1
# ANDB_EMBEDDER_MODEL=text-embedding-005               # dim=768 (default)
# ANDB_EMBEDDER_MODEL=text-multilingual-embedding-002  # dim=768
# ANDB_EMBEDDER_DIM=768
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
ANDB_VERTEXAI_ACCESS_TOKEN=
# Short-lived OAuth2 token; alternative to service-account JSON

# ─── HuggingFace Inference API ────────────────────────────────────────────────
# ANDB_EMBEDDER=huggingface
# ANDB_EMBEDDER_API_KEY=hf_xxx
# ANDB_EMBEDDER_MODEL=sentence-transformers/all-MiniLM-L6-v2   # dim=384
# ANDB_EMBEDDER_MODEL=sentence-transformers/all-mpnet-base-v2  # dim=768
# ANDB_EMBEDDER_MODEL=BAAI/bge-m3                              # dim=1024
# ANDB_EMBEDDER_MODEL=intfloat/multilingual-e5-large           # dim=1024
# ANDB_EMBEDDER_DIM=384
# ANDB_EMBEDDER_TIMEOUT=60   # HuggingFace cold-start can be slow

# ─── Local ONNX (CPU / CUDA) ──────────────────────────────────────────────────
# ANDB_EMBEDDER=onnx
ANDB_EMBEDDER_MODEL_PATH=/path/to/model.onnx
# e.g. models/minilm-l6-v2.onnx  (see models/README.md for download)
ANDB_ONNX_VOCAB_PATH=/path/to/vocab.txt
# e.g. models/minilm-l6-v2-vocab.txt
ANDB_EMBEDDER_DEVICE=cpu
# cpu | cuda   — set cuda to use GPU execution provider
CUDA_VISIBLE_DEVICES=0
# GPU index for ONNX CUDA / TensorRT / GGUF-CUDA providers
ONNXRUNTIME_LIB_PATH=/path/to/libonnxruntime.so
# Linux: /usr/lib/libonnxruntime.so  macOS: /usr/local/lib/libonnxruntime.dylib
ANDB_EMBEDDER_MAX_BATCH_SIZE=32
ANDB_EMBEDDER_DIM=384
# Must match the model output dimension (all-MiniLM-L6-v2 → 384)

# ─── Local GGUF (CPU / CUDA via llama.cpp) ────────────────────────────────────
# ANDB_EMBEDDER=gguf
# ANDB_EMBEDDER_MODEL_PATH=/path/to/model.gguf
# e.g. models/all-MiniLM-L6-v2.Q4_K_M.gguf
ANDB_EMBEDDER_GPU_LAYERS=0
# 0 = CPU only; set to e.g. 32 to offload layers to CUDA GPU
# ANDB_EMBEDDER_DIM=384

# ─── Local TensorRT (CUDA only) ───────────────────────────────────────────────
# ANDB_EMBEDDER=tensorrt
# ANDB_EMBEDDER_MODEL_PATH=/path/to/model.engine
# e.g. models/minilm-l6-v2-fp16.engine  (built via trtexec, see models/README.md)
# ANDB_ONNX_VOCAB_PATH=/path/to/vocab.txt  (same vocab as ONNX)
# ANDB_EMBEDDER_DIM=384

# ─── Agent SDK — Identity ─────────────────────────────────────────────────────
# These are read by agent.LoadFromEnv() when using the CogDB agent SDK.
# Required when running an AgentSession or AgentGateway process.
ANDB_AGENT_ENDPOINT=http://127.0.0.1:8080
# CogDB gateway URL (same server as ANDB_HTTP_ADDR above)
ANDB_AGENT_ID=my-agent-alpha
# Unique identifier for this agent process (e.g. "researcher-01", "planner")
ANDB_TENANT_ID=tenant-default
# Billing / org unit; must match the tenant registered in CogDB
ANDB_WORKSPACE_ID=ws-default
# Memory workspace; agents in the same workspace share a graph partition
ANDB_AGENT_HTTP_PORT=9090
# Port for the AgentGateway listener (used by peer agents in a MAS)
ANDB_AGENT_HTTP_TIMEOUT=30
# Per-request timeout (seconds) for CogDB REST calls

# ─── Agent SDK — LLM Inference Backend ────────────────────────────────────────
# Configures the LLM the agent calls for reasoning / generation.
# Uses the OpenAI chat-completions API shape — compatible with:
#   OpenAI, Azure OpenAI, Ollama, vLLM, LM Studio, DeepSeek, Qwen, etc.
ANDB_AGENT_LLM_BASE_URL=https://api.openai.com/v1
# e.g. http://localhost:11434/v1  (Ollama)
#      https://api.deepseek.com/v1
#      https://dashscope.aliyuncs.com/compatible-mode/v1  (Qwen / Alibaba Cloud)
ANDB_AGENT_LLM_API_KEY=sk-your-key-here
ANDB_AGENT_LLM_MODEL=gpt-4o
# Other examples:
#   deepseek-chat       (DeepSeek)
#   qwen2.5:14b         (Ollama / Qwen local)
#   qwen-max            (Dashscope)
#   claude-3-5-sonnet-20241022  (Anthropic via compatible proxy)
ANDB_AGENT_LLM_MAX_TOKENS=2048
# 0 = use provider default
ANDB_AGENT_LLM_TEMPERATURE=0.7
# 0.0–2.0; lower = more deterministic
ANDB_AGENT_LLM_TIMEOUT=120
# Per-request timeout in seconds (long reasoning tasks may need 120–300)

# ─── Agent SDK — Multi-Agent System (MAS) Topology ────────────────────────────
# Only needed when running more than one agent that must collaborate.
ANDB_MAS_TOPOLOGY=mesh
# mesh        — every agent can share memories with every peer directly
# hub         — all agents route through a single hub agent
# hierarchical — tree-shaped delegation (set per-agent in your topology)
ANDB_MAS_PEERS=
# Comma-separated AgentGateway URLs of sibling agents, e.g.:
#   http://agent-beta:9090,http://agent-gamma:9090
ANDB_MAS_HUB_AGENT_ID=
# Only required when ANDB_MAS_TOPOLOGY=hub; set to the hub's ANDB_AGENT_ID

# ─── S3 / MinIO Integration ───────────────────────────────────────────────────
# Optional: enable local MinIO/S3 integration tests.
# This is a local-dev example; do not paste real production secrets.
S3_ENDPOINT=127.0.0.1:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=andb-integration
S3_SECURE=false
S3_REGION=us-east-1
S3_PREFIX=andb/integration_tests
