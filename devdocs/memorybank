14. 伪代码示例

class MemoryGovernor:
    def ingest(self, interaction):
        candidates = extract_memory_candidates(interaction)
        objects = [materialize(c) for c in candidates]
        admitted = []
        for obj in objects:
            score = admission_score(obj)
            if score >= TH_ACTIVE:
                obj.state = "active"
                admitted.append(obj)
            elif score >= TH_SESSION:
                obj.state = "session_only"
            else:
                obj.state = "discarded"
        update_summaries(admitted)
        update_profiles(admitted)
        persist(admitted)
        return admitted

    def retrieve(self, query_context, scope, budget):
        candidates = multi_channel_recall(query_context, scope, budget)
        candidates = [m for m in candidates if visible(m, scope)]
        candidates = [m for m in candidates if not quarantined(m)]
        candidates = [m for m in candidates if valid(m)]
        ranked = sorted(candidates, key=lambda m: final_score(m, query_context), reverse=True)
        packet = pack_by_bucket(ranked[:budget])
        return packet

    def post_use_update(self, used_memory_ids, now):
        for m in load_memories(used_memory_ids):
            m.recall_count += 1
            m.strength_score += reinforcement_delta(m)
            m.last_recalled_at = now
            m.retention_score = recompute_retention(m)
            persist(m)

    def periodic_governance(self, now):
        for m in load_active_memories():
            m.retention_score = decay(m, now)
            if detect_conflict(m):
                m.quarantine_flag = True
            if should_archive(m):
                m.state = "archived"
            persist(m)


