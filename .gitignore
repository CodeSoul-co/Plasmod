# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.pytest_cache/

# Editor/IDE
# .idea/
# .vscode/

# 成员私有文档（不推送到 GitHub）
成员B_检索模块方案.md
成员B_检索模块指南.md
retrieval_internal_guide.md
B_检索模块第一周设计文档.md
B_第二周实现文档.md
B_第三周实现文档.md
B_第四周实现文档.md
方案定位.md
agent-native-db-spec.md
rule

# Dev artifacts (generated by scripts/dev)
scripts/dev/artifacts/

# Local dev server logs
server.*.log

# Local MinIO data (Docker volume)
.minio-data/

# Member A / local full-stack acceptance (Badger + WAL under ANDB_DATA_DIR)
.acceptance-e2e-data/

# Local server data / capture outputs (not for commit)
.andb_data/
out/

# Old integration run artifacts (moved to scripts/dev/artifacts/)
s3-integration-run-record-*.md
s3-go-integration-output-*.txt
integration_tests/s3-python-output-*.txt

# Local dev test files (not for push)
src/retrieval/test_*.py
系统分层架构图.md
方案.md
分工情况.md
arch-design.zh-CN.md

# Build artifacts & compiled binaries
build/
cpp/build/
server

# 非 README 的项目 md 文档（不推送到 GitHub）
RETRIEVAL_B.md
ingest-storage-object-workers.md
src/internal/platformpkg/UPSTREAM_README.md

# Local TLS roots for Docker andb (PEM); keep directory via .gitkeep only
docker/custom-ca/*
!docker/custom-ca/.gitkeep
