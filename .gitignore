# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.pytest_cache/

# Editor/IDE
# .idea/
# .vscode/

# 成员私有文档（不推送到 GitHub）
成员B_检索模块方案.md
成员B_检索模块指南.md
retrieval_internal_guide.md
B_检索模块第一周设计文档.md
B_第二周实现文档.md
B_第三周实现文档.md
B_第四周实现文档.md
方案定位.md
agent-native-db-spec.md
rule

# Dev artifacts (generated by scripts/dev)
scripts/dev/artifacts/

# Local dev server logs
server.*.log

# Local MinIO data (Docker volume)
.minio-data/

# Old integration run artifacts (moved to scripts/dev/artifacts/)
s3-integration-run-record-*.md
s3-go-integration-output-*.txt
integration_tests/s3-python-output-*.txt

# Local dev test files (not for push)
src/retrieval/test_*.py
